<Window x:Class="ExcelToSQLTable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelToSQLTable"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Excel Row -->
            <RowDefinition Height="Auto"/>
            <!-- DB Info Header -->
            <RowDefinition Height="Auto"/>
            <!-- Server -->
            <RowDefinition Height="Auto"/>
            <!-- Database -->
            <RowDefinition Height="Auto"/>
            <!-- Username -->
            <RowDefinition Height="Auto"/>
            <!-- Password -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Message -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Labels -->
            <ColumnDefinition Width="*"/>
            <!-- Text Inputs -->
            <ColumnDefinition Width="Auto"/>
            <!-- Browse Button -->
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <Label Grid.Row="0" Grid.ColumnSpan="3" Content="Excel to SQL Table" Foreground="Purple" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Excel File Input -->
        <Label Grid.Row="1" Grid.Column="0" Content="Excel file:" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBox x:Name="txtExcel" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,0,304,36" Grid.RowSpan="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        <Button Grid.Row="1" Grid.Column="1" Content="Browse" Click="Browse_clk" Margin="398,0,219,36" Grid.RowSpan="3"/>

        <!-- Server Name -->
        <Label Grid.Row="3" Grid.Column="0" Content="Server:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <TextBox x:Name="txtsevername" Grid.Row="3" Grid.Column="1" Margin="0,10,381,36" Grid.RowSpan="2" VerticalContentAlignment="Center"/>

        <!-- Database -->
        <Label Grid.Row="4" Grid.Column="0" Content="Database:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <TextBox x:Name="txtdatabase" Grid.Row="4" Grid.Column="1" Margin="0,10,381,36" Grid.RowSpan="2" VerticalContentAlignment="Center"/>

        <!-- Username -->
        <Label Grid.Row="5" Grid.Column="0" Content="Username:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <TextBox x:Name="txtusername" Grid.Row="5" Grid.Column="1" Margin="0,10,381,36" Grid.RowSpan="2" VerticalContentAlignment="Center"/>

        <!-- Password -->
        <Label Grid.Row="6" Grid.Column="0" Content="Password:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <TextBox x:Name="txtpassword" Grid.Row="6" Grid.Column="1" Margin="0,10,381,3" VerticalContentAlignment="Center" TextChanged="On_TextChanged"/>
        <CheckBox x:Name="chkShowPass" Content="Show Password" Grid.Column="1" Margin="318,14,233,5" Grid.Row="6" Checked="CheckBox_CheckUnCheck" Unchecked="CheckBox_CheckUnCheck"/>

        <!-- Save & Create Table Buttons -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="3" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Save Connection" Width="140" Margin="10,10" Click="Connect_clk"/>
        </StackPanel>
        <StackPanel x:Name="stkCreate" Grid.Row="8" Grid.ColumnSpan="3" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,20,0,20" Width="367" Visibility="Hidden">
            <StackPanel Orientation="Horizontal">
                <Label Content="Table Name:" Margin="10,10,0,10">
                </Label>
                <TextBox x:Name="tableName" Width="200" Margin="10,10,0,10" VerticalAlignment="Center"></TextBox>
            </StackPanel>
            <Button x:Name="btnCreate" Content="Create Table" Width="140" Margin="10,10,10,10" Visibility="Visible" Click="CreateTable_Click"/>
        </StackPanel>

        <Label x:Name="msgBox" Grid.Row="9" Grid.ColumnSpan="3" Content="" Visibility="Visible" HorizontalAlignment="Center" Margin="10" FontSize="15"/>
    </Grid>

</Window>
